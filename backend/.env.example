# KrishiYantra Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection URI
# Local MongoDB (default):
MONGO_URI=mongodb://localhost:27017/krishiyantra

# JWT Secret Key (change this to a strong random string in production!)
SECRET_KEY=krishi_secret_key_change_in_production_2024

# Razorpay keys (test mode)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Contact email delivery (Gmail SMTP example)
CONTACT_RECEIVER_EMAIL=vj572483@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_sender_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_EMAIL=your_sender_email@gmail.com

# Flask settings
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# Comma-separated allowed origins for browser requests in production.
# Example: https://your-site.netlify.app,https://www.yourdomain.com
# Use * only for development/testing.
CORS_ORIGINS=*
